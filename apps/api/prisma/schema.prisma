model TeacherAssistantAssessment {
  id             String                     @id @default(uuid())
  tenantId       String
  teacherId      String
  subject        String
  pluginKey      String
  gradeId        String?
  classIds       Json
  name           String
  assessmentType String
  totalMarks     Float
  dueAt          DateTime?
  status         String                     @default("DRAFT")
  uploads        Json?
  settings       Json?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  questions      TeacherAssistantQuestion[]
  scripts        TeacherAssistantScript[]
  jobs           TeacherAssistantJob[]
  auditEvents    TeacherAssistantAudit[]

  @@index([tenantId, teacherId, status])
}

model TeacherAssistantQuestion {
  id                 String                           @id @default(uuid())
  assessmentId       String
  questionNumber     String
  questionType       String
  expectedAnswers    Json
  alternativeAnswers Json?
  marks              Float
  tolerance          Float?
  decimalPrecision   Int?
  requiredUnit       String?
  caseSensitive      Boolean                          @default(false)
  ignoreWhitespace   Boolean                          @default(true)
  partialMarkRules   Json?
  sortOrder          Int                              @default(0)
  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt
  assessment         TeacherAssistantAssessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  results            TeacherAssistantQuestionResult[]

  @@unique([assessmentId, questionNumber])
  @@index([assessmentId, sortOrder])
}

model TeacherAssistantScript {
  id                    String                           @id @default(uuid())
  assessmentId          String
  learnerId             String?
  detectedStudentNumber String?
  detectedStudentName   String?
  originalFiles         Json
  extractedText         String?
  editableText          String?
  detectedAnswers       Json?
  status                String                           @default("QUEUED")
  ocrConfidence         Float?
  markingConfidence     Float?
  suggestedTotal        Float?
  finalTotal            Float?
  needsReview           Boolean                          @default(false)
  flags                 Json?
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  reviewedAt            DateTime?
  approvedAt            DateTime?
  publishedAt           DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  assessment            TeacherAssistantAssessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  results               TeacherAssistantQuestionResult[]
  jobs                  TeacherAssistantJob[]
  auditEvents           TeacherAssistantAudit[]

  @@index([assessmentId, status])
  @@index([learnerId, publishedAt])
}

model TeacherAssistantQuestionResult {
  id                String                   @id @default(uuid())
  scriptId          String
  questionId        String
  questionNumber    String
  detectedAnswer    String?
  expectedAnswer    Json
  matchingRule      String
  suggestedMarks    Float
  finalMarks        Float
  ocrConfidence     Float
  markingConfidence Float
  overridden        Boolean                  @default(false)
  teacherNote       String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  script            TeacherAssistantScript   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  question          TeacherAssistantQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([scriptId, questionId])
  @@index([scriptId, questionNumber])
}

model TeacherAssistantJob {
  id           String                     @id @default(uuid())
  tenantId     String
  assessmentId String
  scriptId     String?
  type         String
  status       String                     @default("QUEUED")
  attempts     Int                        @default(0)
  error        String?
  lockedAt     DateTime?
  completedAt  DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  assessment   TeacherAssistantAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  script       TeacherAssistantScript?    @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
}

model TeacherAssistantAudit {
  id           String                     @id @default(uuid())
  tenantId     String
  assessmentId String
  scriptId     String?
  actorId      String?
  action       String
  data         Json?
  createdAt    DateTime                   @default(now())
  assessment   TeacherAssistantAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  script       TeacherAssistantScript?    @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([assessmentId, scriptId, createdAt])
}

